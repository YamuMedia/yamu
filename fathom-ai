<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fathom — Ad Copy Performance Report | Apr 15 – May 5, 2026</title>
  <style>
    :root {
      --bg: #0f1117;
      --surface: #1a1d27;
      --surface2: #22263a;
      --border: #2d3248;
      --text: #e8eaf0;
      --muted: #8b90a8;
      --accent: #6c7aff;
      --accent2: #a78bfa;
      --green: #34d399;
      --yellow: #fbbf24;
      --red: #f87171;
      --bf: #38bdf8;
      --bf-bg: rgba(56, 189, 248, 0.08);
      --bf-border: rgba(56, 189, 248, 0.25);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 14px;
      line-height: 1.6;
    }

    .header {
      background: linear-gradient(135deg, #1a1d27 0%, #0f1117 100%);
      border-bottom: 1px solid var(--border);
      padding: 32px 40px 28px;
    }

    .header-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 16px;
    }

    .header h1 {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.3px;
    }

    .header .meta {
      color: var(--muted);
      font-size: 13px;
      margin-top: 4px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }

    .badge-bf {
      background: var(--bf-bg);
      border: 1px solid var(--bf-border);
      color: var(--bf);
    }

    .nav {
      display: flex;
      gap: 4px;
      padding: 16px 40px 0;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      overflow-x: auto;
    }

    .nav-btn {
      padding: 10px 18px;
      border: none;
      border-bottom: 2px solid transparent;
      background: transparent;
      color: var(--muted);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.15s;
    }

    .nav-btn:hover {
      color: var(--text);
    }

    .nav-btn.active {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }

    .section {
      display: none;
      padding: 32px 40px;
      max-width: 1400px;
      margin: 0 auto;
    }

    .section.active {
      display: block;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 32px;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 20px;
    }

    .card.highlight {
      border-color: var(--bf-border);
      background: var(--bf-bg);
    }

    .card .label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .card .value {
      font-size: 26px;
      font-weight: 700;
      line-height: 1.2;
    }

    .card .sub {
      font-size: 12px;
      color: var(--muted);
      margin-top: 4px;
    }

    .card.highlight .value {
      color: var(--bf);
    }

    .section-title {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .section-sub {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 20px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      margin-bottom: 28px;
    }

    thead {
      background: var(--surface2);
    }

    th {
      padding: 10px 14px;
      text-align: left;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: var(--muted);
      white-space: nowrap;
      border-bottom: 1px solid var(--border);
    }

    td {
      padding: 10px 14px;
      font-size: 13px;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }

    tr:last-child td {
      border-bottom: none;
    }

    tr:hover td {
      background: rgba(255, 255, 255, 0.02);
    }

    .bf-row td {
      background: var(--bf-bg);
    }

    .bf-row:hover td {
      background: rgba(56, 189, 248, 0.12) !important;
    }

    .asset-text {
      max-width: 340px;
    }

    .asset-text .text {
      font-size: 13px;
      line-height: 1.4;
    }

    .asset-text .tags {
      display: flex;
      gap: 4px;
      margin-top: 5px;
      flex-wrap: wrap;
    }

    .tag {
      display: inline-block;
      padding: 1px 7px;
      border-radius: 3px;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.4px;
    }

    .tag-bf {
      background: var(--bf-bg);
      border: 1px solid var(--bf-border);
      color: var(--bf);
    }

    .tag-best {
      background: rgba(52, 211, 153, 0.1);
      border: 1px solid rgba(52, 211, 153, 0.3);
      color: var(--green);
    }

    .tag-good {
      background: rgba(108, 122, 255, 0.1);
      border: 1px solid rgba(108, 122, 255, 0.3);
      color: var(--accent);
    }

    .tag-learning {
      background: rgba(251, 191, 36, 0.1);
      border: 1px solid rgba(251, 191, 36, 0.3);
      color: var(--yellow);
    }

    .tag-low {
      background: rgba(248, 113, 113, 0.1);
      border: 1px solid rgba(248, 113, 113, 0.3);
      color: var(--red);
    }

    .tag-pending {
      background: rgba(139, 144, 168, 0.1);
      border: 1px solid rgba(139, 144, 168, 0.3);
      color: var(--muted);
    }

    .tag-pinned {
      background: rgba(167, 139, 250, 0.1);
      border: 1px solid rgba(167, 139, 250, 0.3);
      color: var(--accent2);
    }

    .num {
      text-align: right;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }

    .num-green {
      color: var(--green);
      font-weight: 600;
    }

    .num-red {
      color: var(--red);
    }

    .num-yellow {
      color: var(--yellow);
    }

    .num-bf {
      color: var(--bf);
      font-weight: 600;
    }

    .bar-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .bar {
      height: 6px;
      border-radius: 3px;
      min-width: 2px;
      background: var(--accent);
    }

    .bar-bf {
      background: var(--bf);
    }

    .bar-green {
      background: var(--green);
    }

    .alert {
      padding: 14px 18px;
      border-radius: 8px;
      font-size: 13px;
      margin-bottom: 20px;
    }

    .alert-info {
      background: rgba(108, 122, 255, 0.08);
      border: 1px solid rgba(108, 122, 255, 0.25);
      color: var(--accent);
    }

    .alert-warn {
      background: rgba(251, 191, 36, 0.08);
      border: 1px solid rgba(251, 191, 36, 0.25);
      color: var(--yellow);
    }

    .alert-success {
      background: rgba(52, 211, 153, 0.08);
      border: 1px solid rgba(52, 211, 153, 0.25);
      color: var(--green);
    }

    .grid2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 28px;
    }

    .panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 20px;
    }

    .panel h3 {
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 14px;
      color: var(--text);
    }

    .panel-item {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 8px 0;
      border-bottom: 1px solid var(--border);
      gap: 12px;
    }

    .panel-item:last-child {
      border-bottom: none;
    }

    .panel-item .pi-text {
      font-size: 12px;
      color: var(--text);
      line-height: 1.4;
      flex: 1;
    }

    .panel-item .pi-meta {
      font-size: 11px;
      color: var(--muted);
      text-align: right;
      white-space: nowrap;
    }

    .panel-item .pi-conv {
      font-size: 13px;
      font-weight: 700;
      color: var(--green);
    }

    .replace-table td {
      vertical-align: top;
    }

    .replace-tag {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
      margin-bottom: 4px;
    }

    .replace-remove {
      background: rgba(248, 113, 113, 0.1);
      border: 1px solid rgba(248, 113, 113, 0.3);
      color: var(--red);
    }

    .replace-add {
      background: rgba(52, 211, 153, 0.1);
      border: 1px solid rgba(52, 211, 153, 0.3);
      color: var(--green);
    }

    .replace-reason {
      font-size: 12px;
      color: var(--muted);
    }

    .campaign-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 22px;
      margin-bottom: 20px;
    }

    .campaign-card h3 {
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .campaign-card .cc-meta {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 14px;
    }

    .cc-stats {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 16px;
      padding: 12px 16px;
      background: var(--surface2);
      border-radius: 8px;
      border: 1px solid var(--border);
    }

    .cc-stat .cc-stat-label {
      font-size: 10px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.6px;
    }

    .cc-stat .cc-stat-val {
      font-size: 18px;
      font-weight: 700;
      margin-top: 2px;
    }

    .bf-highlight {
      background: var(--bf-bg);
      border: 1px solid var(--bf-border);
      border-radius: 8px;
      padding: 12px 16px;
      margin-top: 12px;
      font-size: 13px;
    }

    .bf-highlight strong {
      color: var(--bf);
    }

    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .list-block {
      background: var(--surface2);
      border-radius: 8px;
      padding: 14px;
    }

    .list-block h4 {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .list-item {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 5px 0;
      border-bottom: 1px solid var(--border);
      gap: 8px;
      font-size: 12px;
    }

    .list-item:last-child {
      border-bottom: none;
    }

    .list-item .li-text {
      flex: 1;
      line-height: 1.4;
    }

    .list-item .li-stat {
      color: var(--muted);
      white-space: nowrap;
      font-size: 11px;
    }

    .li-green {
      color: var(--green);
      font-weight: 600;
    }

    .li-bf {
      color: var(--bf);
    }

    .footnote {
      font-size: 12px;
      color: var(--muted);
      margin-top: 10px;
      padding: 10px 14px;
      background: var(--surface2);
      border-radius: 6px;
      border-left: 3px solid var(--border);
    }

    @media (max-width: 768px) {

      .header,
      .nav,
      .section {
        padding-left: 20px;
        padding-right: 20px;
      }

      .grid2,
      .two-col {
        grid-template-columns: 1fr;
      }

      .asset-text {
        max-width: 200px;
      }
    }
  </style>
</head>

<body>

  <div class="header">
    <div class="header-top">
      <div>
        <h1>Fathom — Ad Copy Performance Report</h1>
        <div class="meta">April 15 – May 5, 2026 &nbsp;·&nbsp; Conversion: Qualified Sign-up &nbsp;·&nbsp; 12 campaigns
          analyzed</div>
      </div>
      <span class="badge badge-bf">● Bot-free launch: Apr 15</span>
    </div>
  </div>

  <div class="nav">
    <button class="nav-btn active" onclick="show('exec')">Exec Summary</button>
    <button class="nav-btn" onclick="show('botfree')">Bot-Free Analysis</button>
    <button class="nav-btn" onclick="show('headlines')">Search Headlines</button>
